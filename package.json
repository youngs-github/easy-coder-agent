{
  "name": "easy-coder-agent",
  "version": "0.3.0",
  "description": "A simplified AI coding assistant CLI tool",
  "keywords": [
    "easy-coder",
    "easy-coder-agent",
    "mini-claude-code",
    "coding-agent",
    "agentic",
    "llm",
    "ai"
  ],
  "license": "MIT",
  "author": {
    "name": "youngs-github",
    "url": "https://github.com/youngs-github/easy-coder-agent"
  },
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "easy-coder": "dist/main.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path');const s=p.join(__dirname,'src/skills'),d=p.join(__dirname,'dist/skills');if(fs.existsSync(s))fs.cpSync(s,d,{recursive:true})\"",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist"
  ]
}
